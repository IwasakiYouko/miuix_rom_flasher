#!/sbin/sh
set -e
ZIP=$3
OUTFD=/proc/self/fd/$2;
ui_print() { echo -e "ui_print $1\nui_print" > $OUTFD; }
partitionPath="/dev/block/bootdevice/by-name"

if [ -d /tmp/Hanfy ];then rm -r /tmp/Hanfy ; fi
mkdir -p /tmp/Hanfy/bin
unzip "$ZIP" META-INF/bin/* -d /tmp/Hanfy
mv /tmp/Hanfy/META-INF/bin/* /tmp/Hanfy/bin/
unzip "$ZIP" META-INF/Structure -d /tmp/Hanfy
unzip "$ZIP" META-INF/DeviceName -d /tmp/Hanfy
unzip "$ZIP" META-INF/DeviceCPU -d /tmp/Hanfy
unzip "$ZIP" META-INF/rom_info -d /tmp/Hanfy
mkdir -p tmp/Magisk
unzip "$ZIP" magisk.apk -d /tmp/Magisk/Magisk.apk
chmod -R 0777 /tmp/Hanfy
Structure=$(cat '/tmp/Hanfy/META-INF/Structure')
HanfyDevice=$(cat '/tmp/Hanfy/META-INF/DeviceName')
DeviceCPU=$(cat '/tmp/Hanfy/META-INF/DeviceCPU')
export PATH=/tmp/Hanfy/bin:$PATH

if [ "Mtk" == "$DeviceCPU" ]; then
	partitionPath="/dev/block/by-name"
fi


ui_print "$(echo "$ZIP")"

if [ "$ZIP" = "/sideload/package.zip" ]; then
	ui_print "[信息] 检测到ADB Sideload刷机"
	ui_print "[信息] 当前刷机方式不支持校验ROM包完整性"
	ui_print "[信息] 已跳过校验ROM包完整性"
	ui_print "[信息] 请自行在电脑上校验ROM包完整性"
	ui_print "[INFO] 5"
	sleep 1
	ui_print "[INFO] 4"
	sleep 1
	ui_print "[INFO] 3"
	sleep 1
	ui_print "[INFO] 2"
	sleep 1
	ui_print "[INFO] 1"
	sleep 1
else
	ui_print "正在校验ROM包完整性"
	localmd5=$(md5sum "$ZIP")
	if [[ "$ZIP" != *"${localmd5:0:6}"* ]]
	then
		ui_print "未在本地包名中找到对应的MD5，该ROM包已损坏"
		exit 1
	fi
	ui_print "已完成校验ROM包完整性"
fi


ui_print " ***********************************************  "
ui_print " "
ui_print "              欢迎使用 Hanfy丶ROM                  "
ui_print ""
ui_print "		2024-2025 宫水三叶团队 精心打造"
ui_print " ***********************************************  "
ui_print " "

if [ "$HanfyDevice" = "star" ];
then
	if [ "$(getprop ro.product.device)" != "star" ] && [ "$(getprop ro.product.device)" != "mars" ];
	then
		ui_print "机型不匹配，刷入失败！"
		exit 1
	fi
else
	if [ "$(getprop ro.product.device)" != "$HanfyDevice" ];
	then
		ui_print "机型不匹配，刷入失败！"
		exit 1
	fi
fi
	
ui_print "ROM系统正在刷入中,过程有点久,请耐心等待……"

for brxFile in $(7zz l "$ZIP" | grep -o "[a-z]*.zstd"); do
	partition=${brxFile%%.*}
	ui_print " 正在刷入 ${partition} 系统分区"
	7zz x -so "$ZIP" "${brxFile}" | brx -c -d > "${partitionPath}/${partition}" 
done

for imageFile in $(7zz l "$ZIP" | grep firmware-update | grep -o "/.*" ); do
	partition=${imageFile##*/}
	partition=${partition%%.*}
	ui_print " 正在刷入 ${partition} 系统分区"
	
	if [ "$partition" == "preloader_raw" ] || [ "$partition" == "sspm" ] || [ "$partition" == "tee" ] || [ "$partition" == "scp" ] || [ "$partition" == "mcupm" ] || [ "$partition" == "gz" ] || [ "$partition" == "lk" ] ||  [ "$partition" == "dpm" ] ;then
		for partitionItem in $(ls $partitionPath | grep $partition);do
			unzip -p "$ZIP" "firmware-update${imageFile}" > "${partitionPath}/${partitionItem}"		
		done
	elif [ "$partition" == "boot" ] && [ "$Structure" == "VAB" ] ;then
		unzip -p "$ZIP" "firmware-update${imageFile}" > "${partitionPath}/${partition}_a"
		unzip -p "$ZIP" "firmware-update${imageFile}" > "${partitionPath}/${partition}_b"
	elif [ "$partition" == "preloader_ufs" ] ;then
		unzip -p "$ZIP" "firmware-update${imageFile}" > "${partitionPath}/sda"
		unzip -p "$ZIP" "firmware-update${imageFile}" > "${partitionPath}/sdb"
	elif [ "$partition" == "preloader_emmc" ] ;then
		unzip -p "$ZIP" "firmware-update${imageFile}" > "/dev/block/mmcblk0boot0"
		unzip -p "$ZIP" "firmware-update${imageFile}" > "/dev/block/mmcblk0boot1"
	else
		unzip -p "$ZIP" "firmware-update${imageFile}" > "${partitionPath}/${partition}" 
	fi
done

rm -rf /data/dalvik-cache/arm/*
rm -rf /data/dalvik-cache/arm64/*

if [ -f /tmp/Hanfy/bin/updateM ];
then
	source /tmp/Hanfy/bin/updateM "$@"
else
	ui_print "刷机脚本不存在！"
fi

ui_print "系统刷入完成…………"
ui_print " **************  温馨提示  ***************  "
ui_print " "
ui_print " 1、刷入如出现 挂载错误、CUST错误 ，直接重启既可"
ui_print " 2、刷机失败的推荐使用线刷，此包自带线刷工具，解压即可直刷."
ui_print " 3、刷机如遇到错误请前往'TWRP'的'高级'菜单中导出刷机日记进行反馈."
ui_print " "
ui_print " ***********************************************  "

exit 0
